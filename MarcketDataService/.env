#enter your posgresql user name here
DB_USERNAME=postgres

#enter your posgresql password here
DB_PASSWORD=password

#for container, use the host.docker.internal 
BD_HOST=localhost

#data base collums params
SYMBOL_MAX_LENGTH=20
EXCHANGE_NAME_MAX_LENGTH=20
PRICE_PRECISION=18
PRICE_SCALE=8
VOLUME_PRECISION=18
VOLUME_SCALE=8

CACHE_TTL_PER_MINUTES=1
